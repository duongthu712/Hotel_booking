<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <servlet>
        <servlet-name>HomeServlet</servlet-name>
        <servlet-class>controller.HomeServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>LoginController</servlet-name>
        <servlet-class>controller.LoginController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>UserProfileController</servlet-name>
        <servlet-class>controller.UserProfileController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ChangePasswordController</servlet-name>
        <servlet-class>controller.ChangePasswordController</servlet-class>
    </servlet>
    <servlet>
 
        <servlet-name>ServiceListController</servlet-name>
        <servlet-class>controller.ServiceListController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ServiceEditController</servlet-name>
        <servlet-class>controller.ServiceEditController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ServiceDeleteController</servlet-name>
        <servlet-class>controller.ServiceDeleteController</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ServiceCreateController</servlet-name>
        <servlet-class>controller.ServiceCreateController</servlet-class>
 
        <servlet-name>HotelPolicyServlet</servlet-name>
        <servlet-class>controller.HotelPolicyServlet</servlet-class>
 
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginController</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>LogoutController</servlet-name>
        <servlet-class>controller.LogoutController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutController</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ForgotPasswordController</servlet-name>
        <servlet-class>controller.ForgotPasswordController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ForgotPasswordController</servlet-name>
        <url-pattern>/forgot-password</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>VerifyCodeController</servlet-name>
        <servlet-class>controller.VerifyCodeController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>VerifyCodeController</servlet-name>
        <url-pattern>/verify-code</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ResetPasswordController</servlet-name>
        <servlet-class>controller.ResetPasswordController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ResetPasswordController</servlet-name>
        <url-pattern>/reset-password</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
 
        <servlet-name>ServiceListController</servlet-name>
        <url-pattern>/ServiceList</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ServiceEditController</servlet-name>
        <url-pattern>/ServiceEdit</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ServiceDeleteController</servlet-name>
        <url-pattern>/ServiceDelete</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ServiceCreateController</servlet-name>
        <url-pattern>/ServiceCreate</url-pattern>
 
        <servlet-name>HotelPolicyServlet</servlet-name>
        <url-pattern>/policies</url-pattern>
 
    </servlet-mapping>
</web-app>
